{
  "name": "paddle-check",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:app": "node scripts/generate-build-version.mjs && tsc -b && vite build",
    "build:app:pages": "node scripts/generate-build-version.mjs && tsc -b && vite build --mode gh-pages",
    "build": "npm run build:docs",
    "build:single-html": "node scripts/build-single-html.mjs",
    "build:docs": "npm run build:app:pages && npm run build:single-html",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
